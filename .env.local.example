# 本番 URL（Vercel デプロイ後に実際の URL に変更する）
NEXT_PUBLIC_SITE_URL=https://hiki-log.vercel.app

# 閲覧数カウント用 Upstash Redis（Vercel Storage > Upstash から取得）
# Vercel が自動設定するプレフィックス付き変数名を使用する
HIKI_LOG_KV_REST_API_URL=
HIKI_LOG_KV_REST_API_TOKEN=

# giscus コメントシステム（giscus.app でリポジトリを設定して取得）
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
